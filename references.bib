@ARTICLE{Das2025,
	author = {Das, Sumanta and Dutta, Suman and Choudhury, Malini Roy and Garai, S. and Mukherjee, Siddhartha and Sengupta, Sudip and Jana, Soujanya and Dey, Saikat and Dhar, Anannya and Dutta, Sayantika and Awasthi, Amit},
	title = {Regenerating rural soil and ecosystems: A 15-year systematic review of emerging methods and technologies},
	year = {2025},
	journal = {Science of the Total Environment},
	volume = {990},
	pages = {},
	doi = {10.1016/j.scitotenv.2025.179926},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105008345373&doi=10.1016%2Fj.scitotenv.2025.179926&partnerID=40&md5=70a90e2d7a7b89a79102b2fbd2c55fd1},
	affiliations = {Ramakrishna Mission Vivekananda Educational and Research Institute, School of Environment and Disaster Management, Howrah, India; The University of Queensland, School of Agriculture and Food Sustainability, Brisbane, Australia; Ramakrishna Mission Vivekananda Educational and Research Institute, Department of Genetics and Plant Breeding, Howrah, India; Ramakrishna Mission Vivekananda Educational and Research Institute, Division of Agronomy, Howrah, India; Ramakrishna Mission Vivekananda Educational and Research Institute, Rural and Tribal Development, Howrah, India; Swami Vivekananda University, School of Agriculture, Barrackpore, India; Ramakrishna Mission Vivekananda Educational and Research Institute, School of Agriculture and Rural Development, Howrah, India; University of Petroleum and Energy Studies, Dehradun, India},
	abstract = {Rural soil and ecosystem degradation continue to threaten global food security, biodiversity, and environmental stability. While conventional remediation approaches remain cost-intensive and contextually limited, recent advancements have introduced novel methods and technologies for soil regeneration. This systematic review synthesizes 15 years (2010–2024) of peer-reviewed literature retrieved from the SCOPUS database, focused on emerging regenerative approaches, including bioremediation techniques, agroecological practices, microbial inoculants, biochar applications, and artificial intelligence (AI) and remote sensing-integrated monitoring systems. Emerging technologies are defined here as innovations developed or significantly advanced within the past two decades and demonstrating potential for field-scale application. Bibliometric and thematic analyses were conducted to map trends, collaboration networks, and conceptual thematic developments. A subsequent qualitative synthesis evaluated the effectiveness, scalability, and ecological relevance of these methods across diverse rural settings. Results indicate a significant increase in interdisciplinary research linking agronomy, soil science, ecology, and geospatial science, yet highlight persistent barriers to adoption among smallholder systems and a scarcity of localized, adaptive solutions. Unlike previous reviews, this study uniquely integrates quantitative bibliometric data synthesis with qualitative critical appraisal of real-world applications to provide a comprehensive and practice-oriented approach to soil regeneration pathways. Overall, the findings offer novel insights for designing region-specific strategies and underscore the need for scalable, technology-integrated frameworks that align scientific innovation with traditional knowledge systems. Such integrated approaches can support policymakers, researchers, and practitioners in improving soil health and promoting sustainable agricultural practices. © 2025 Elsevier B.V., All rights reserved.},
	author_keywords = {Agroecology; Bibliometric analysis; Bioremediation; Emerging technologies; Soil regeneration; Soil restoration and health},
	keywords = {Biodiversity; Biotechnology; Ecosystems; Integrated control; Knowledge based systems; Knowledge management; Remote sensing; Rural areas; Soil conservation; Soil pollution; Soils; Agro ecologies; Bibliometrics analysis; Ecosystem degradation; Emerging technologies; Global food security; Soil degradation; Soil health; Soil regeneration; Soil restoration; Systematic Review; Bioremediation; charcoal; soil organic matter; artificial intelligence; biochar; bioremediation; environmental restoration; literature review; policy making; regeneration; remote sensing; rural area; soil conservation; soil ecosystem; soil remediation; agroecology; agronomy; bibliometrics; biodiversity; climate change; ecology; ecosystem; environmental sustainability; food security; immobilization; multidisciplinary care; nonhuman; nutrient immobilization; quality control; Review; rural soil; soil; soil health; soil regeneration; systematic review; thematic analysis},
	correspondence_address = {S. Das; School of Environment and Disaster Management, Ramakrishna Mission Vivekananda Educational and Research Institute, Kolkata, West Bengal, 700103, India; email: sumanta.das@uq.net.au},
	publisher = {Elsevier B.V.},
	issn = {00489697; 18791026},
	coden = {STEVA},
	language = {English},
	abbrev_source_title = {Sci. Total Environ.},
