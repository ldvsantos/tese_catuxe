@ARTICLE{Tian-Liang2025,
	author = {Tian-Liang, null and Huang, Shengzhuo and Zeng, Jun and Liu, Shoubai and Jin, Honglei and Chen, Yijun and Tsambaa, Battseren and Mandakh, Urtnasan and Zheng, Xilong and Mei, Wenli and Borjigidai, Almaz and Dai, Haofu},
	title = {Ethnobotanical study of traditional medicinal plants used by the Miao people in Hainan, China},
	year = {2025},
	journal = {Journal of Ethnobiology and Ethnomedicine},
