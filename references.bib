@article{Ciocco2023,
   abstract = {Indigenous Knowledge (IK) is increasingly involved in the contemporary management of natural resources. Tribal wildlife management programs in the United States may be uniquely positioned to effectively and ethically integrate their IK. While a narrow focus on the body of IK and a particular management activity may suffice for project'level integration efforts, herein we consider how IK integration at the programmatic level may be best supported. We propose a holistic conceptual framework of preconditions including sovereignty, the North American Model management, funding, cultural resources, stakeholder support, and programmatic leadership. We assess the current status and common challenges with each precondition and illustrate their potential roles for a more lasting and pervasive integration of IK into tribal wildlife management programs.},
   author = {Tony Ciocco and Stefan Tangen and Chad Smith},
   doi = {10.1002/wsb.1467},
   issn = {2328-5540},
   issue = {3},
   journal = {Wildlife Society Bulletin},
   month = {9},
   title = {Actualizing Indigenous Knowledge in tribal wildlife management: basic preconditions},
   volume = {47},
   year = {2023}
}

@article{Reyes-Garca2019,
   abstract = {Indigenous Peoples and local communities (IPLC) are affected by global environmental change because they directly rely on their immediate environment for meeting basic livelihood needs. Therefore, safeguarding and restoring ecosystem resilience is critical to support their well-being. Based on examples from the literature, we illustrate how IPLC participate in restoration activities maintaining traditional practices, restoring land degraded by outsiders, and joining outside groups seeking to restore ecosystems. Our review also provides examples of how Indigenous and Local Knowledge can be incorporated in the planning, execution, and monitoring of restoration activities. However, not all restoration initiatives engaging IPLC are beneficial or successful, and the factors that lead to success are not fully known. While local involvement in restoration projects is often mentioned as an element of success, this is primarily associated to projects that actively involve IPLC in codesigning restoration activities affecting their territories, ensure both short-term direct benefits to IPLC and long-term support of the maintenance of restored areas, and recognize IPLC local traditions and customary institutions. Based on these examples, we argue that IPLC should be a more important focus in any post-2020 CBD agenda on restoration.},
   author = {Victoria Reyes-Garcaa and alvaro Fernandez-Llamazares and Pamela McElwee and Zsolt Molnar and Kinga allerer and Sarah J. Wilson and Eduardo S. Brondizio},
   doi = {10.1111/REC.12894},
   issn = {1526-100X},
   issue = {1},
   journal = {Restoration Ecology},
   keywords = {Indigenous and Local Knowledge (ILK),comanagement,cultural keystone species,ecosystem services,traditional management},
   month = {1},
   pages = {3-8},
   publisher = {John Wiley \& Sons, Ltd},
   title = {The contributions of Indigenous Peoples and local communities to ecological restoration},
   volume = {27},
   url = {https://onlinelibrary.wiley.com/doi/full/10.1111/rec.12894 https://onlinelibrary.wiley.com/doi/abs/10.1111/rec.12894 https://onlinelibrary.wiley.com/doi/10.1111/rec.12894},
   year = {2019}
}


@article{Gomes2016,
   abstract = {O presente estudo objetivou demonstrar a violaaao constitucional constante na recente Lei n' 13.123/2015, que dita sobre o acesso ao patrimanio genatico, sobre a proteaao e o acesso ao conhecimento tradicional associado e sobre a repartiaao de benefacios para conservaaao e uso sustentavel da biodiversidade, que revogou a Medida Provisaria n' 2.186-16/2001. A recente Lei tomou uma posiaao centralizadora quanto ao controle e exploraaao do patrimanio genatico existente no Paas, quando disciplinou que sao de competancia da Uniao a gestao, o controle e a fiscalizaaao das atividades descritas no ato normativo, desrespeitando o art. 23 (incisos III, VI e VIII) da Constituiaao da Repablica de 1988 (CR/1988). Para tal compreensao foi feito um estudo da Lei Complementar n' 140/2011 em comparaaao com a legislaaao em debate, apontando os aspectos geradores do desrespeito a norma constitucional paradigma. Para esta investigaaao foi utilizado o matodo hipotatico-indutivo, com pesquisa explicativa qualitativa, utilizando-se o levantamento bibliografico.},
   author = {Magno Federici Gomes and Carlos Frederico Saraiva de Vasconcelos},
   doi = {10.5902/1981369421490},
   issn = {1981-3694},
   issue = {1},
   journal = {Revista Eletranica do Curso de Direito da UFSM},
   month = {6},
   pages = {348},
   title = {Das atribuiaaes administrativas na gestao e supervisao do patrimanio genatico Brasileiro},
   volume = {11},
   year = {2016}
}


@article{Tsai2020,
   abstract = {This paper explores how the Amis people on the east coast of Taiwan who practice freediving spearfishing manage the local marine area. Among the coastal Amis people, freediving spearfishing is not only a way of life but is also closely related to ritual ceremonies. Amis spearfishing men are knowledgeable of the near-shore sea and coast, and the practice of spearfishing collectively cultivates their ability to deal with both public affairs and human relations in the community. However, the Taiwanese government regards spearfishing guns as weapons and restricts them. Furthermore, the assumption that spearfishing destroys the coral ecosystem and fishery resources means that the practice is often demonized or increasingly restrained. In this paper, I argue that local marine Traditional Ecological Knowledge (TEK) among Amis spearfishing men can be the foundation for local marine conservation under the concept of community-based natural-resource management (CBNRM), involving both the local Amis community and the government, in spite of both parties still having their own issues to overcome.},
   author = {Futuru C. L. Tsai},
   doi = {10.3390/su12187770},
   issn = {2071-1050},
   issue = {18},
   journal = {Sustainability},
   month = {9},
   pages = {7770},
   title = {Shuttling between Land and Sea: Contemporary Practices among Amis Spearfishing Men as a Foundation for Local Marine-Area Management},
   volume = {12},
   year = {2020}
}

@article{LimaVerdanRangel2018,
   abstract = {<p>A cultura brasileira a o resultado daquilo que era praprio das populaaaes tradicionais indagenas e das transformaaaes trazidas pelos diversos grupos colonizadores e escravos africanos. Nesta toada, ao se analisar o meio ambiente cultural, enquanto complexo macro sistema, a perceptavel que a algo incorpareo, abstrato, fluado, constituado por bens culturais materiais e imateriais portadores de referancia a memaria, a aaao e a identidade dos distintos grupos formadores da sociedade brasileira. O conceito de patrimanio histarico e artastico nacional abrange todos os bens moveis e imaveis, existentes no Paas, cuja conservaaao seja de interesse pablico, por sua vinculaaao a fatos memoraveis da Histaria patria ou por seu excepcional valor artastico, arqueolagico, etnografico, bibliografico e ambiental. Neste passo, o presente busca, a partir da intervenaao do Estado na propriedade, por meio do instituto do tombamento cultural, analisar as alteraaaes no patrimanio cultural do municapio de Cachoeiro de Itapemirim-ES, em especial na ambiancia da Igreja de Nosso Senhor dos Passos, em razao do das modificaaaes no traaado urbano, advindos do Empreendimento Hugo Amorim Residencial.</p><p>'</p><p>Brazilian culture is the result of what was typical of the traditional indigenous populations and the changes brought about by the various settlers and African slaves groups. In this tune, when analyzing the cultural environment as complex macro system, it is noticeable that it is something intangible, abstract, fluid, consisting of cultural material and immaterial goods bearing reference to memory, action and identity of the various groups that form the Brazilian society. The concept of historical and artistic heritage covers all mobile and immovable property, existing in the country, whose conservation is in the public interest, for their connection to memorable events of history homeland or for exceptional artistic, archaeological, ethnographic, bibliographic and environmental . In this step, this search from the state intervention in the property, through the cultural tipping Institute, analyzing the changes in the cultural heritage of the Cachoeiro de Itapemirim-ES, especially in the ambience of the Church of Our Lord of Steps, because of the changes in the urban layout, arising from the Enterprise Hugo Amorim Residential.</p>},
   author = {Taua Lima Verdan Rangel},
   doi = {10.47096/redap.v1i2.94},
   issn = {2595-5667},
   issue = {2},
   journal = {Revista de Direito da Administraaao Pablica},
   month = {1},
   title = {Intervenaao do Estado na propriedade em prol da preservaaao do patrimanio cultural: uma analise do tombamento da Igreja de Nosso Senhor dos Passos e a limitaaao ao direito de construir},
   volume = {1},
   year = {2018}
}

