@article{Lima2010,
   abstract = {O objetivo do estudo foi analisar as representaaaes sociais construadas pelos sergipanos sobre os andios. Foram entrevistados 378 moradores de seis cidades (cinco em Sergipe e uma em Alagoas). Os resultados obtidos indicam o predomanio de uma representaaao social cujo nacleo central a formado por elementos que referem um tempo passado e remoto, ou que denotam a distancia fasica e cultural (como "matas", "florestas", "nudez", "pintura"). Igualmente, quando perguntados sobre o que lembram dos andios na histaria do Brasil, os entrevistados raramente referem acontecimentos recentes e tam mesmo dificuldade para produzir qualquer enunciaaao. O fato de morar longe ou perto de uma tribo indagena teve menos impacto nas representaaaes sociais do que esperavamos. As conclusaes indicam que, para muitos dos pesquisados, os andios existem apenas como uma ausancia ou ainda de um modo naturalizado, como reminiscancias fenotapicas e culturais de uma histaria de 500 anos de violancia e extermanio.},
   author = {Marcus Euganio Oliveira Lima and Alan Magno Matos de Almeida},
   doi = {10.1590/S0103-863X2010000100004},
   issn = {0103-863X},
   issue = {45},
