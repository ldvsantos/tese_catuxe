@ARTICLE{Mérida Ponce2019,
	author = {Mérida Ponce, J. P. and Hernández Calderón, M. A. and Comandini, Ornella and Rinaldi, Andrea C. and Flores Arzú, R.},
	title = {Ethnomycological knowledge among Kaqchikel, indigenous Maya people of Guatemalan Highlands},
