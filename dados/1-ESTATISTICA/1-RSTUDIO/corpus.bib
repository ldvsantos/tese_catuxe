@ARTICLE{Wubetu2017,
	author = {Wubetu, Muluken and Abula, Teferra and Kibret, G. D.},
	title = {Ethnopharmacologic survey of medicinal plants used to treat human diseases by traditional medical practitioners in Dega Damot district, Amhara, Northwestern Ethiopia},
