@CONFERENCE{Namriah2023,
	author = {Namriah, Reza Aditya Amdy and Amdy, Muhamad Farid and Anshori, Teguh Ananda},
	title = {Local Soil Classification System As A Tool For Transferring Agricultural Technology In Developing Rural Areas},
	year = {2023},
	journal = {AIP Conference Proceedings},
	volume = {2628},
	pages = {},
	doi = {10.1063/5.0146106},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85163391475&doi=10.1063%2F5.0146106&partnerID=40&md5=40b7f45ab0216461bebe5b56316b8609},
	affiliations = {Universitas Halu Oleo, Department of Soil Sciences, Kendari, Indonesia},
	abstract = {Sustainable agricultural development is an important and strategic issue to be discussed today. This study aims to ellaborate the knowledge and experience of local farmers in managing their lands for agricultural production using the methods the integrative-approach interview and descriptive-qualitative survey. This research was carried out on June until July 2021 to local Tolaki ethnic farmers in Laey a District, South Konawe Regency. The results showed that the local Tolaki ethnic farmers classify their soil based on the colors of their soils to indicate the fertility of the soil. Three types of soils, were observed. Firstly, the black soil was named wutame'eto to be more fertile than others it was considered better for the use of planting agricultural crops. Secondly for red soil. It was named wutamome'a. This soil was considered less fertile because only certain crops could be planted in this soil. Lastly, it was yellow soil was named wutamokunindonia. This soil was considered the most less fertile. The soil was hard and difficult to cultivate. This study was concluded that the local ethnic of Tolaki farmers in Laeya District of South Konawe Regency used soil color as a parameter to assess soil fertility. The implication of this study is the importance of studying local wisdom and local knowledge that obtained as inheritance (blueprints) knowledge which was transferred from generation to generation as a process of life experience that is lived. Using this knowledge system operated at the level of everyday life as an individual and collective effort to solve life's problems could be use as a tool of communication to develop the rural area. © 2023 Elsevier B.V., All rights reserved.},
