	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105020914681&doi=10.3233%2FFAIA250626&partnerID=40&md5=e064a6cd3a06d4ae195fe8b78d70f832},
	affiliations = {SmartBear Software, Bear, United States; University of California, San Diego, La Jolla, United States},
	abstract = {The rapid advancement of Artificial Intelligence (AI) presents unique opportunities for preserving and revitalizing cultural heritage and traditional craftsmanship. This paper proposes a novel approach to training AI systems using archival documentary footage, specifically focusing on ensuring ethical data practices and empowering Indigenous communities. Our approach is grounded in the Global Indigenous Data Alliance's “Indigenous Peoples' Rights in Data” framework, which outlines 12 key principles for ethical data governance.[1] These principles, including “the rights to possess, consent, refuse, benefit, and use data originating from a given community,” inform our proposed methodology. By providing clear guidelines on data governance, we aim to encourage traditionally closed cultures to share their practices, ensuring that the preservation efforts benefit the communities themselves. AI systems trained on archival footage and informed by ethical data practices can be seen as a state-of-the-art form of salvage ethnography and empower communities to maintain control over their traditional knowledge and cultural heritage. This approach has the potential to ensure that diverse artistic practices and traditional craftsmanship continue to thrive in the age of AI. © 2025 Elsevier B.V., All rights reserved.},
