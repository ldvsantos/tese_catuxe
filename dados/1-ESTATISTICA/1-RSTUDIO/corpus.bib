@ARTICLE{Ulicsni2016,
	author = {Ulicsni, Viktor and Svanberg, Ingvar and Molnár, Zsolt},
	title = {Folk knowledge of invertebrates in Central Europe - folk taxonomy, nomenclature, medicinal and other uses, folklore, and nature conservation},
