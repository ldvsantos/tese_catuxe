@ARTICLE{Rollo2025,
	author = {Rollo, Maria Fernanda},
	title = {Interconnected Nature and People: Biosphere Reserves and the Power of Memory and Oral Histories as Biocultural Heritage for a Sustainable Future},
	year = {2025},
