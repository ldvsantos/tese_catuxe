@ARTICLE{Pavlik2021,
	author = {Pavlik, Bruce Michael and Louderback, Lisbeth A. and Vernon, Kenneth Blake and Yaworsky, Peter M. and Wilson, Cynthia and Clifford, Arnold and Codding, Brian F.},
	title = {Plant species richness at archaeological sites suggests ecological legacy of Indigenous subsistence on the Colorado Plateau},
	year = {2021},
	journal = {Proceedings of the National Academy of Sciences of the United States of America},
	volume = {118},
	number = {21},
	pages = {},
	doi = {10.1073/pnas.2025047118},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85106374942&doi=10.1073%2Fpnas.2025047118&partnerID=40&md5=57a01038d8b4f893d9e78d4b28f21698},
	affiliations = {The University of Utah, Conservation Department, Salt Lake City, United States; Natural History Museum of Utah, Salt Lake City, United States; University of Utah, College of Social and Behavioral Science, Salt Lake City, United States; The University of Utah, Archaeological Center, Salt Lake City, United States; The University of Utah, Global Change and Sustainability Center, Salt Lake City, United States; Salt Lake City Corporation, Traditional Foods Program, Salt Lake City, United States},
	abstract = {Humans have both intentional and unintentional impacts on their environment, yet identifying the enduring ecological legacies of past small-scale societies remains difficult, and as such, evidence is sparse. The present study found evidence of an ecological legacy that persists today within an semiarid ecosystem of western North America. Specifically, the richness of ethnographically important plant species is strongly associated with archaeological complexity and ecological diversity at Puebloan sites in a region known as Bears Ears on the Colorado Plateau. A multivariate model including both environmental and archaeological predictors explains 88% of the variation in ethnographic species richness (ESR), with growing degree days and archaeological site complexity having the strongest effects. At least 31 plant species important to five tribal groups (Navajo, Hopi, Zuni, Ute Mountain Ute, and Apache), including the Four Corners potato (Solanum jamesii), goosefoot (Chenopodium sp.), wolfberry (Lycium pallidum), and sumac (Rhus trilobata), occurred at archaeological sites, despite being uncommon across the wider landscape. Our results reveal a clear ecological legacy of past human behavior: even when holding environmental variables constant, ESR increases significantly as a function of past investment in habitation and subsistence. Consequently, we suggest that propagules of some species were transported and cultivated, intentionally or not, establishing populations that persist to this day. Ensuring persistence will require tribal input for conserving and restoring archaeo-ecosystems containing “high-priority” plant species, especially those held sacred as lifeway medicines. This transdisciplinary approach has important implications for resource management planning, especially in areas such as Bears Ears that will experience greater visitation and associated impacts in the near future. © 2021 Elsevier B.V., All rights reserved.},
	author_keywords = {Ethnobotany | archaeo-ecosystems | species richness | Solanum jamesii | Bears Ears},
	keywords = {article; bear; Chenopodium; Colorado; ear; ecosystem; ethnobotany; globus pallidus; human; human cell; investment; Lycium; nonhuman; potato; propagule; resource management; Rhus; species richness; sustenance; adaptation; agriculture; archeology; biodiversity; classification; cultural anthropology; growth, development and aging; history; multivariate analysis; plant; procedures; Solanum; Adaptation, Physiological; Agriculture; Anthropology, Cultural; Archaeology; Biodiversity; Ecosystem; History, Ancient; Humans; Multivariate Analysis; Plants},
	correspondence_address = {B.M. Pavlik; Red Butte Garden, Department of Conservation, University of Utah, Salt Lake City, 84108, United States; email: bruce.pavlik@redbutte.utah.edu},
	publisher = {National Academy of Sciences},
