@ARTICLE{Hou2024,
	author = {Hou, Shuwang and Yu, Mengfan and Yao, Zhen},
	title = {Ethnobotanical study on factors influencing plant composition and traditional knowledge in homegardens of Laifeng Tujia ethnic communities, the hinterland of the Wuling mountain area, central China},
	year = {2024},
	journal = {Journal of Ethnobiology and Ethnomedicine},
	volume = {20},
