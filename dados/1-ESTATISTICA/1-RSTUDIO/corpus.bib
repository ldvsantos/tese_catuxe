@ARTICLE{Vij2026287,
	author = {Vij, Sonakshi and Singhal, Achal and Tewari, Anvesh},
	title = {Region-Specific Agricultural Advisory Systems Using Retrieval-Augmented Generation},
	year = {2026},
	journal = {Lecture Notes in Networks and Systems},
	volume = {1608 LNNS},
	pages = {287 - 300},
	doi = {10.1007/978-3-032-03740-4_23},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105021809737&doi=10.1007%2F978-3-032-03740-4_23&partnerID=40&md5=1de1c6dabca7195af7b5ca7cc1339eb5},
	affiliations = {Vivekananda Institute of Professional Studies - Technical Campus, School of Engineering and Technology, New Delhi, India},
	abstract = {Wasteful resource use, degraded soil, and significant post-harvest losses are just a few of the grave sustainability challenges South Asian agriculture presents that endanger the UN Sustainable Development Goal (SDG) 12: Responsible Consumption and Production. A subset of artificial intelligence (AI), Retrieval-Augmented Generation (RAG) systems have revolutionary potential for providing practical, regionally relevant agricultural recommendations. This paper develops a RAG-based advisory system especially meant for smallholder farmers in South Asia by combining indigenous agricultural knowledge with scientific literature from AGRIS. The system uses advanced language models like Falcon-7B-Instruct and Llama-3.2-3B-Instruct to generate context-aware responses on post-harvest loss reduction, water optimisation, and soil fertility management. Although farmers’ qualitative assessments highlight usability and practical effect, quantitative studies using BLEU-4 and ROUGE-L metrics reveal great accuracy and relevance. Sustainability forecasts indicate that post-harvest losses (18%) and chemical fertiliser use (22%) will much decline, which fits SDG 12 objectives. Additionally, information is provided taking sustainability as an important factor. This study addresses significant voids in AI-driven agriculture and paves the way for scalable solutions that support sustainable farming practices by including indigenous knowledge, emphasising regional specificity, and maximising deployment for low-resource settings. © 2025 Elsevier B.V., All rights reserved.},
	keywords = {Agribusiness; Artificial intelligence; Smart agriculture; Sustainable agriculture; Sustainable development; Sustainable development goals; Advisory systems; Degraded soils; Generation systems; Language model; Post-harvest loss; Resource use; Scientific literature; Smallholder farmers; South Asia; System use; Harvesting},
	correspondence_address = {A. Singhal; VIPS School of Engineering and Technology, Vivekananda Institute of Professional Studies-Technical Campus, New Delhi, India; email: achals2002@gmail.com},
	editor = {Swaroop, A. and Virdee, B. and Correia, S. and Polkowski, Z.},
	publisher = {Springer Science and Business Media Deutschland GmbH},
	issn = {23673389; 23673370},
	isbn = {9789819652372; 9783031931055; 9789819662968; 9783031999963; 9783031950162; 9783031947698; 9783032004406; 9783031910074; 9783031926105; 9783031877032},
	language = {English},
	abbrev_source_title = {Lect. Notes Networks Syst.},
	type = {Conference paper},
	publication_stage = {Final},
