@ARTICLE{Haile2022382,
	author = {Haile, Bewuketu and Tesfaye, Bizuayehu and Olango, Temesgen Magule},
	title = {Indigenous Biosystematics of Enset (Ensete ventricosum [Welw.] Cheesman) in its Center of Origin and Diversity, Southwest Ethiopia: Folk Nomenclature, Classification, and Descriptors},
	year = {2022},
