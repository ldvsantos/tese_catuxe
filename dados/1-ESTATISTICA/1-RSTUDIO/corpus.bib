@ARTICLE{Biswas2017231,
	author = {Biswas, Soumyajit and Shaw, Rupa and Bala, S. and Mazumdar, Asis},
	title = {Inventorization of some ayurvedic plants and their ethnomedicinal use in Kakrajhore forest area of West Bengal},
	year = {2017},
