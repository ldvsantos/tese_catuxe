}

@ARTICLE{Jeddi2024,
	author = {Jeddi, Samir and Ferioun, Mohamed and Benkhaira, Nesrine and Jeddi, Mohamed and El Hachlafi, Naoufal and Fikri-Benbrahim, Kawtar},
	title = {Ethnobotanical appraisal of indigenous medicinal plants used in the Taounate region (Northern Morocco): Qualitative and quantitative approaches},
