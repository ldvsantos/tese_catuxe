}

@ARTICLE{McNiven2021413,
	author = {McNiven, Ian J. and Lambrides, Ariana B.J.},
	title = {STONE-WALLED FISH TRAPS OF AUSTRALIA AND NEW GUINEA AS EXPRESSIONS OF ENHANCED SOCIALITY},
	year = {2021},
	pages = {413 - 448},
	doi = {10.1093/oxfordhb/9780190095611.013.49},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85123391815&doi=10.1093%2Foxfordhb%2F9780190095611.013.49&partnerID=40&md5=c32a37c0a43e7179138ed64f8a7c152e},
	affiliations = {Monash University, Melbourne, Australia; ARC Centre of Excellence for Australian Biodiversity and Heritage, Wollongong, Australia; James Cook University, Townsville, Australia},
	abstract = {Fishing was and remains an important subsistence activity of many coastal and inland Indigenous peoples of Australia and New Guinea. The range of ethnographically known fishing methods used to obtain freshwater and marine fishes is similar across the two regions. This ethnographic picture of diversity and complexity is not matched archaeologically, where stone-walled fish traps dominate. Archaeological research on stone-walled fish traps has focused on technical dimensions (e.g., mapping, classification, and dating) and social dimensions (e.g., gender, social complexity, and social organization). Stone-walled fish traps can transform the social and ecological landscape and, in an archaeological context, provide an opportunity to explore decision making and the sociocultural changes associated with the installation of these fixed-in-place facilities. Relevant social organizational changes with potential material correlates amenable to archaeological research include the restructuring of residential sites; interregional gatherings and exchange relationships; aquatic resource enhancement and regularization; and ownership and control of facilities and resources, including territorial partitioning of land- and seascapes. © 2024 Elsevier B.V., All rights reserved.},
	author_keywords = {Indigenous fishing; interregional gatherings; landscapes; ownership; resource enhancement; seascapes; stone-walled fish traps},
	publisher = {Oxford University Press},
	isbn = {9780190095611; 9780190095628},
	language = {English},
	abbrev_source_title = {The Oxf. Handbook of the Archaeology of Indigenous Australia and New Guin.},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 6}
}

