@ARTICLE{Diop20221,
	author = {Diop, Amadou Lamine and Malan, Djah François and Kougbo, Ménéké Distel},
	title = {Perception of malaria and cultural diversity of antimalarial plants in three sympatric communities: Agni, Akyé and Gwa in the District of Alépé, Côte d’Ivoire},
	year = {2022},
	journal = {Asian Journal of Ethnobiology},
	volume = {5},
