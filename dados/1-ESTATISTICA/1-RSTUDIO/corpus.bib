@ARTICLE{Lozano-Paredes20251159,
	author = {Lozano-Paredes, Luis H.},
	title = {Localising the Global: “Creole Platforms” and the Reimagining of Urban Digital Landscapes},
	year = {2025},
	journal = {Lecture Notes in Civil Engineering},
	volume = {591 LNCE},
