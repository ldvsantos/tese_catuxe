@ARTICLE{Doumecq2018491,
	author = {Doumecq, María Belén and Arenas, Patricia Marta},
	title = {What wood is good for firewood? Local botanical knowledge in firewood stores of La Plata district, Buenos Aires (Argentina); ¿Qué madera es buena para leña? Conocimiento botánico local en "leñeras" del partido de La Plata (Buenos Aires, Argentina)},
	year = {2018},
	journal = {Boletin de la Sociedad Argentina de Botanica},
