	correspondence_address = {X.-F. Yang; Key Laboratory of Economic Plants and Biotechnology, Kunming Institute of Botany, Chinese Academy of Sciences, Kunming, China; email: xuefei@mail.kib.ac.cn},
	publisher = {BioMed Central Ltd},
