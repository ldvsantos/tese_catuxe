}

@ARTICLE{Aknonero202385,
	author = {Aknonero, Ronald and Hege, Samson and Pok, Matthew and Wossa, Stewart W.},
	title = {Complementarity of scientific analysis and ancestral knowledge systems for diversification of food sources: A case study of pandanus from jiwaka province, Papua New Guinea},
	year = {2023},
	pages = {85 - 108},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85173042826&partnerID=40&md5=0093410fcf37dcf6b12f20db9cfe6c34},
	affiliations = {University of Goroka, Guinea; University of Goroka's, Guinea},
	abstract = {This study documents the classification and nomenclature of a species of Pandanus conoideus, locally known as marita, based on traditional knowledge systems. The traditional preparation method of steam cooking the fruits before extraction of their oil was applied. This was compared with the oil yield obtained through solvent extraction of the raw samples. The results for physico-chemical properties show that marita oil can be a source of edible oil and help to diversify the sources of vegetable oils, confirming the value of traditional taxonomies and preparation methods for indigenous foods. Its high oil content could also lead to many industrial applications and address food security and sustainable development. The research discovered, however, that most people in Kauil are not aware of the importance of traditional knowledge, and the varieties of marita were new to some of the local people. Further research in the area is vital to avoid loss of knowledge. © 2023 Elsevier B.V., All rights reserved.},
	publisher = {Peter Lang AG},
	isbn = {9781789977738; 9781789977721},
	language = {English},
	abbrev_source_title = {Small Islands, Big Issues: Pac. Perspect. on the Ecosyst. of Knowl.},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

