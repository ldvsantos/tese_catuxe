}

@ARTICLE{Kuralneethi20211384,
	author = {Kuralneethi, Silambarasi and Sariman, Sarina and Ulaganathan, Vaidehi},
	title = {Gender and age differences in the relationship between calorie, macronutrients intake and growth status of school-aged Aboriginal children at Labu, Negeri Sembilan},
	year = {2021},
	journal = {British Food Journal},
