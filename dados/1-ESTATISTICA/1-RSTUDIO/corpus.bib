	title = {Ethnobotanical Study of Medicinal Plants in Tehuledere District, Northwest Ethiopia},
	year = {2024},
	journal = {Scientific World Journal},
	volume = {2024},
	pages = {},
	doi = {10.1155/2024/3420352},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85205606127&doi=10.1155%2F2024%2F3420352&partnerID=40&md5=5a7353da33a88dfc30fd6b82a12f9869},
	affiliations = {Debark University, Department of Biology, Debark, Ethiopia; Makdela Amba University, Department of Biology, Tulu Awlia, Ethiopia},
	abstract = {Medicinal plants have constituted a fundamental aspect of human health and wellness for millennia. The objective of this study was to document medicinal plants used to treat human and livestock ailments in the Tehuledere District. The data were collected using semistructured interviews, focus group discussions, and field observations with local informants. Preference ranking, direct matrix ranking, and informant consensus factor were used for data analysis. A total of 63 medicinal plant species belonging to 59 genera and 41 families were documented. The predominant families identified were Lamiaceae and Asteraceae, each containing 6 and 5 species, respectively. Of the recorded medicinal plants, 53 (80.95%) species were used for human ailments, whereas 12 (19.05%) species were used for animal health issues. Among the recorded medicinal plant species, shrubs constitute the highest number with 35% species. The most frequently used plant parts were leaves, accounting for 59% of remedies targeting human ailments. The administration of herbal treatments was primarily oral, aimed at addressing various diseases. The most significant threat to these medicinal plants was attributed to agricultural expansion, followed by the collection of firewood. The aim of documenting the use of medicinal plants in the treatment of diseases was to capture traditional practices, with species such as Eucalyptus globulus, Olea europaea subsp. cuspidata, and Lepidium sativum serving as the foundational basis for future pharmacological studies. It is imperative to prioritize the conservation of Laggera tomentosa and Urtica simensis to safeguard biodiversity and the cultural traditions associated with these endangered species. Engaging local communities in the management and conservation of plant resources, along with the preservation of their traditional knowledge, presents a cost-effective and sustainable solution. © 2024 Elsevier B.V., All rights reserved.},
	keywords = {animal health; article; Asteraceae; biodiversity; endangered species; Ethiopia; Eucalyptus globulus; human; Lamiaceae; Lepidium sativum; livestock; medicinal plant; nonhuman; olive tree; pharmacology; phytotherapy; plant leaf; semi structured interview; shrub; Urtica; African medicine; animal; chemistry; classification; ethnobotany; female; male; procedures; Animals; Ethnobotany; Female; Humans; Male; Medicine, African Traditional; Phytotherapy; Plants, Medicinal},
	correspondence_address = {Y. Yiblet; Department Biology, Mekdela Amba University, Tulu Awuliya, Ethiopia; email: yalewyiblet@gmail.com},
	publisher = {Hindawi Limited},
	issn = {1537744X; 23566140},
	pmid = {39364257},
	language = {English},
	abbrev_source_title = {Sci. World J.},
	type = {Article},
