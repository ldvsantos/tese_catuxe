@ARTICLE{Carrillo-Galván2020,
	author = {Carrillo-Galván, Guadalupe and Bye, Robert A. and Eguiarte, Luis E. and Cristians, Sol and Pérez-López, Pablo and Vergara-Silva, Francisco and Luna-Cavazos, Mario},
	title = {Domestication of aromatic medicinal plants in Mexico: Agastache (Lamiaceae)- A n ethnobotanical, morpho-physiological, and phytochemical analysis},
	year = {2020},
	journal = {Journal of Ethnobiology and Ethnomedicine},
	volume = {16},
	number = {1},
