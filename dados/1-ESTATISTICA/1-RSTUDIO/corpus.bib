	author = {Skinner, Kelly and Neufeld, Hannah Tait and Murray, Emily and Hajto, Suzanne and Andrews, Laurie and Garrett, Anne},
	title = {Sharing Indigenous Foods Through Stories and Recipes},
	year = {2021},
	journal = {Canadian Journal of Dietetic Practice and Research},
