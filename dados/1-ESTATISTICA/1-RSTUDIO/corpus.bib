	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105017596951&doi=10.1007%2Fs00146-025-02655-6&partnerID=40&md5=29e3bc31ecef9ee7f8aef8ea27e53dfd},
	affiliations = {Minjiang University, Fuzhou, China; Silpakorn University, Nakhon Pathom, Thailand; Ltd., Quanzhou, China},
	abstract = {This study investigates the deep cultural dependencies of artificial intelligence (AI) applications within the fashion design sector of the Global South. Through detailed analysis of in-depth interviews with 21 designers and 120 h of participant observation, the research reveals that the effectiveness of AI is not determined by the tools alone, but by the interpretation and reconstruction of local cultural symbols and traditional knowledge. The study proposes a “Technology as Cultural Translator” framework and constructs a “Technology–Culture Compatibility Model.” This model explicates from three dimensions—tools, symbols, and ethics—how designers achieve creative autonomy and cultural reproduction through practices of “technological performance,” “labor value reconstruction,” and “cultural resistance” against the pressures of globalized technological discourse. This research enriches existing theories of technological adaptation and provides practical implications for policy, education, and industry in Global South design practices, including proposals for a “Global South AI Fashion Alliance,” “Critical AI Literacy” courses, and “Cultural Compensation Algorithms.” © 2025 Elsevier B.V., All rights reserved.},
