	keywords = {article; attitude; Catholic; ceremony; forest; fruit; human; human cell; land use; religion; ritual; semi structured interview; socialism; summer; Ukraine; Ukrainian (people); Christianity; classification; ethnobotany; flower; knowledge; plant; symbolism; Ceremonial Behavior; Ethnobotany; Flowers; Knowledge; Plants},
	correspondence_address = {N. Stryamets; Ca’ Foscari University of Venice, Venice, Via Torino, 155, Italy; email: Nataliya.Stryamets@unive.it},
