@ARTICLE{Alrhmoun2025,
	author = {Alrhmoun, Mousaab and Guiggi, Valter and Gillani, Syed Waseem and Manzoor, Muhammad Tariq and Sulaiman, Naji and Pieroni, Andrea},
	title = {Diachronic changes in local food heritage: the ethnobiology of wild foods in central Tuscany},
	year = {2025},
	journal = {Journal of Ethnobiology and Ethnomedicine},
