@ARTICLE{Collins2023,
	author = {Collins, Jack C. and Hu, Jie and McMillan, Sara S. and O'Reilly, Claire L. and El-Den, Sarira and Kelly, Fiona S. and Spinks, Jean Marie and Riley, Toni and Wheeler, Amanda J.},
	title = {Medication-related problems identified by community pharmacists: a descriptive case study of two Australian populations},
	year = {2023},
	journal = {Journal of Pharmaceutical Policy and Practice},
