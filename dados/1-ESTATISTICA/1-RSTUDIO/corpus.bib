	title = {A Cluster Analysis of Cooperative Recycling Behaviors for Post-Consumer Plastic Waste in Urban Areas: A Case Study on Sendai, Kawasaki, and Kyoto City in Japan},
	year = {2025},
	journal = {Sustainability (Switzerland)},
	volume = {17},
