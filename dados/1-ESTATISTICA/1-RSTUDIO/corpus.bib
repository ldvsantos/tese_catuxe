	title = {Understanding Observed Agricultural Landscape Change in Đồng Tháp Province, Vietnam: Local Perceptions and Drivers of Land Use and Land Cover Change around Tràm Chim National Park},
	year = {2025},
	pages = {210 - 233},
	doi = {10.1201/9781003396260-13},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105010990089&doi=10.1201%2F9781003396260-13&partnerID=40&md5=70392f2526f710e486df9f6c69663474},
	affiliations = {Berea College, Department of Philosophy, Berea, United States; Miami University, Oxford, United States; Independent Researcher, Bemidji, United States; NASA Ames Research Center, Moffett Field, United States; University of California, Berkeley, Berkeley, United States; University of Maryland, College Park, College Park, United States; University of Social Sciences and Humanities, Ho Chi Minh City, Ho Chi Minh City, Viet Nam; ISciences LLC, United States; Inc, Kansas City, United States},
	abstract = {This chapter discusses the fusion of remote sensing, geospatial, social sciences, and humanities methodologies to describe and explain landscape change in communities adjacent to Tràm Chim National Park in Đồng Tháp Province, Vietnam. Using the published Landsat-based land cover/land use change (LCLUC) classifications for 2015 to 2019, quantitative change assessments were assessed individually and compared to local knowledge. Building on familial and long-term professional collaboration with communities in the regions, in addition to two field seasons in 2018 and 2019, interviews of individuals’ perceptions of change were matched against remote observations of change. Finally, combining these interviews with official statistical data, a qualitative discourse analysis of local press and public-facing government websites was then used to develop explanations of the drivers of change identified via satellite imagery and the communities themselves. This work culminated in a local economic history of LCLUC. While individuals were not always accurate predictors of observed LCLUC—nor able to ascribe potential economic or policy drivers of the landscape changes that were independently monitored via the satellite imagery—the discourse analysis provided a valuable tool in identifying local drivers of change and potential future trajectories of LCLUC. This work benefitted from the rich archive of 16-day Landsat imagery. Still, future work should focus on mapping high temporal LCLUC in this complex agricultural system via fusion products like the Harmonized Landsat and Sentinel-2 (HLS) product or through weekly to monthly tasks of very high resolution commercial satellite imagery. © 2025 Elsevier B.V., All rights reserved.},
	keywords = {Agriculture; Land use; Landsat; Agricultural landscapes; Discourse analysis; Geo-spatial; Land cover land use changes; Land use and land cover change; LANDSAT; Landscape changes; National parks; Remote-sensing; Viet Nam; Remote sensing},
