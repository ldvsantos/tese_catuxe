	author = {Sanni, Gazali B.T.A. and Ezin, Vincent A. and Ahanchédé, Adam},
	title = {Farmers’ knowledge, practices and use of sesame genetic resources in the production systems of Benin: case study of agro-ecological zone IV},
	year = {2022},
	journal = {Heliyon},
	volume = {8},
