	issn = {22120963},
	language = {English},
	abbrev_source_title = {Clim. Risk Manage.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 4; All Open Access; Gold Open Access}
}

