@ARTICLE{Kichu20155,
	author = {Kichu, Meyanungsang and Malewska, Teresa and Akter, Kaisarun and Imchen, Imchawati and Harrington, David G. and Kohen, James L. and Vemulpad, Subramanyam R. and Jamie, Joanne F.},
	title = {An ethnobotanical study of medicinal plants of Chungtia village, Nagaland, India},
	year = {2015},
	journal = {Journal of Ethnopharmacology},
