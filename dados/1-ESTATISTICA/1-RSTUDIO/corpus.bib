@ARTICLE{Ganni Mampo2025,
	author = {Ganni Mampo, Orou Moctar and Guedje, Kossi François and Merz, Bruno and Yarou, Halissou and MacDonald, Elena and Alamou, Adéchina Eric},
	title = {Farmers’ perceptions of hydroclimatic variability and climate change: survey-based insights in Northern Benin, West Africa},
	year = {2025},
	journal = {Frontiers in Water},
	volume = {7},
	pages = {},
	doi = {10.3389/frwa.2025.1530395},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105010945060&doi=10.3389%2Ffrwa.2025.1530395&partnerID=40&md5=66e2c44d7a591358b770ef3b9d12915b},
	affiliations = {University of Abomey-Calavi, Graduate Research Program on Climate Change and Water Resources, Cotonou, Benin; University of Abomey-Calavi, Laboratory of Applied Hydrology, Cotonou, Benin; GFZ Helmholtz Centre for Geosciences, Section 4.4 Hydrology, Potsdam, Germany; University of Abomey-Calavi, Cotonou, Benin; Universität Potsdam, Institute of Environmental Science and Geography, Potsdam, Germany; Laboratoire de Géoscience de l’Environnement et Application (LaGEA/UNSTIM), Abomey, Benin},
	abstract = {Farmers in West Africa face increasing challenges from droughts and hydroclimatic variability, exacerbated by climate change. Understanding these changes and their drivers is crucial for developing effective adaptation strategies. This study investigates farming households in Northern Benin, assessing their knowledge of hydroclimatic variability and identifying the factors influencing their understanding. Using a questionnaire survey of 509 households across 96 villages in eight municipalities, we analysed both qualitative and quantitative data through statistical methods and machine learning methods. Results reveal that while 71% of farmers have a solid grasp of local hydroclimatic variability, significant gaps remain regarding its underlying causes; only 9% attributed temperature increases to global climate change. Older farmers (mean age: 55 years) and those with over 30 years of experience demonstrated higher knowledge than less experienced farmers. Conversely, formal education had little to no impact. These findings highlight the critical role of indigenous knowledge, accumulated through long-term environmental interaction, in shaping climate awareness. They underscore the need to integrate indigenous knowledge with formal education to improve the understanding of the drivers of these changes. Targeted investments in education, alongside leveraging the experiential knowledge of older farmers, can enhance climate resilience in vulnerable regions. These insights provide a novel perspective on how policymakers can bridge traditional wisdom and modern scientific approaches for more effective climate adaptation. © 2025 Elsevier B.V., All rights reserved.},
	author_keywords = {climate change; farmers; hydroclimatic variability; indigenous knowledge; West Africa},
	correspondence_address = {O.M. Ganni Mampo; Graduate Research Programme on Climate Change and Water Resources (GRP CCWR), West African Science Service Centre on Climate Change and Adapted Land Use (WASCAL), University of Abomey-Calavi, Cotonou, Benin; email: moctarganni@gmail.com},
	publisher = {Frontiers Media SA},
