	author = {Hassan, Musheerul and Mir, Tawseef Ahmad and Jan, Muatasim and Amjad, Muhammad Shoaib and Aziz, Muhammad Abdul and Pieroni, Andrea and Vitasović Kosić, Ivana and Bussmann, Rainer W.},
	title = {Foraging for the future: traditional culinary uses of wild plants in the Western Himalayas–Kashmir Valley (India)},
