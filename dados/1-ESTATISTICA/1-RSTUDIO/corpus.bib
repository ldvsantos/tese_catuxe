@ARTICLE{Girardi2015200,
	author = {Girardi, Cynthia and Butaud, Jean François and Ollier, Corinne and Ingert, Nicolas and Weniger, Bernard and Raharivelomanana, Phila J. and Moretti, Christian},
	title = {Herbal medicine in the Marquesas Islands},
	year = {2015},
	journal = {Journal of Ethnopharmacology},
