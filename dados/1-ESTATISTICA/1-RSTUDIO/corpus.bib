@ARTICLE{Zhang2021,
	author = {Zhang, Yanying and Wurhan, null and Sachula, null and Yongmei, null and Khasbagan, null},
	title = {Ethnobotanical profiles of wild edible plants recorded from Mongolia by Yunatov during 1940–1951},
	year = {2021},
	journal = {History and Philosophy of the Life Sciences},
	volume = {43},
