	author = {Bi, Shibo and Du, Jiacheng and Tian, Zheng and Zhang, Yi},
	title = {Investigating the spatial distribution mechanisms of traditional villages from the human geography region: A case study of Jiangnan, China},
	year = {2024},
	journal = {Ecological Informatics},
	volume = {81},
