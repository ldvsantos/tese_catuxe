	keywords = {Agriculture; Heuristic methods; Population statistics; Regional planning; Rural areas; Security systems; Signal detection; Co-designs; Human animal conflict; Integrating technology; Live-in-lab®; Local knowledge; Participatory approach; Real-time detection; Rural community; Rural development; Rural innovation; Animals},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
