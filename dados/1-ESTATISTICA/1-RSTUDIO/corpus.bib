@ARTICLE{Catarino201671,
	author = {Catarino, LuÃ­s F. and Havik, Philip Jan and Romeiras, Maria M.},
	title = {Medicinal plants of Guinea-Bissau: Therapeutic applications, ethnic diversity and knowledge transfer},
