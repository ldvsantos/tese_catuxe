	title = {What do we talk about when we talk about milpa? A conceptual approach to the significance, topics of research and impact of the mayan milpa system},
	year = {2020},
	journal = {Journal of Rural Studies},
	volume = {77},
	pages = {47 - 54},
	doi = {10.1016/j.jrurstud.2020.04.029},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85084478850&doi=10.1016%2Fj.jrurstud.2020.04.029&partnerID=40&md5=e5716f9f29c9cd26c0cafe8e0e508b87},
	affiliations = {Centro de Investigación en Ciencias de Información Geoespacial, Mexico, Mexico},
	abstract = {The Maya milpa is an ancient agrarian system extended along Mesoamerica, widely known for the slash and burn practices and the polyculture of maize, beans and squashes. Although the Maya milpa has more than three centuries of history, there are several challenges that must be tackled in order to promote the preservation of the system. The aim of this paper is to settle a new starting point in Maya milpa research through a synthesis around the analysis Maya milpa concept, its main lines of research, and its environmental, social, and economic effects in the Yucatan Peninsula. Our research methodology consisted of two different phases: a) the review and analysis of secondary information (169 documents) by means of automated-curation of information (text mining methods) and manual inspection, and b) the design, application, and analysis of 12 interviews using Yucatan Maya milpa researchers as informants. Based on the results we propose some basic elements to consider for an integrative definition of the Maya milpa, we highlight the information gaps described by researchers and checked by wordclouds, and we reveal the most positive and negative impacts of the Maya milpa in terms of environmental, socio-cultural, and economic aspects. © 2020 Elsevier B.V., All rights reserved.},
	author_keywords = {Agroecological systems; Mesoamerica; Milpa; Yucatan peninsula},
	keywords = {agroecology; conceptual framework; environmental impact; farming system; research; socioeconomic impact; traditional knowledge; Yucatan Peninsula; Cucurbita; Zea mays},
	correspondence_address = {K.J. Rodríguez-Robayo; Consejo Nacional de Ciencia y Tecnología, Centro de Investigación en Ciencias de Información Geoespacial, Yucatan, Mexico; email: karla.juliana.rodriguez@gmail.com},
	publisher = {Elsevier Ltd},
	issn = {07430167},
	coden = {JRSTF},
	language = {English},
	abbrev_source_title = {J. Rural Stud.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 32}
}

