@ARTICLE{Agbani2018,
	author = {Agbani, Pierre Onodje and Kafoutchoni, Konoutan Médard and Salako, Kolawole Valere and Gbedomon, Rodrigue Castro and Kégbé, Ahuéfa Mauricel and Karen, Hahn and Sinsin, Brice Augustin},
	title = {Traditional ecological knowledge-based assessment of threatened woody species and their potential substitutes in the Atakora mountain chain, a threatened hotspot of biodiversity in Northwestern Benin, West Africa},
	year = {2018},
	journal = {Journal of Ethnobiology and Ethnomedicine},
	volume = {14},
	number = {1},
