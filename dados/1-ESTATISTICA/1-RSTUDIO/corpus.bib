@ARTICLE{Ishida201591,
	author = {Ishida, Fusako and Tian, Guanglong and Wakatsuki, Toshiyuki},
	title = {Indigenous knowledge and soil management},
	year = {2015},
	pages = {91 - 109},
	doi = {10.2136/sssaspecpub58.ch5},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85102019050&doi=10.2136%2Fsssaspecpub58.ch5&partnerID=40&md5=dc54377f78877652c39e49f7387126d7},
	affiliations = {IITA, Ibadan, Niger; Shimane University, Matsue, Japan},
	abstract = {For generations, farmers have accumulated their own knowledge of soils which can be useful for researchers in developing improved technologies. This chapter synthesized results from case studies on indigenous soil knowledge carried out at Abakaliki (humid forest) and Bida (subhumid savanna) of Nigeria, and analyzed the implications for research on soil management in West Africa. Farmers used color and texture in the classification of their soils to indicate the level of fertility and the labor requirement for land preparation. They also cultivated specific crops on nutrient poor soil to achieve reasonable yields. The soil classification and evaluations by farmers correlated with variations in soil properties obtained from laboratory analysis. They constructed various mounds and ridges with incorporated weeds to control water and maintain soil fertility. Study of the farmers' indigenous soil knowledge implies that research on soil management in West Africa should focus on the development of improved technologies that rely on nutrient recycling, improve soil organic matter levels, conserve soil and water, and are not labor demanding. Integration of trees or cover crops was discussed as possible options to facilitate the shift from low external input agriculture to low external input sustainable agriculture. © 2021 Elsevier B.V., All rights reserved.},
	author_keywords = {Anthropological approach; Capital-based technologies; Ikwo farmers; Indigenous soil knowledge; Izi farmers; soil management; Unscientific approach},
