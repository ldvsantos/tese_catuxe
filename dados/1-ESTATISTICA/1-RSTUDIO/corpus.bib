@ARTICLE{Kheirmandparizi2023,
	author = {Kheirmandparizi, Maryam and Gouin, Jean Philippe and Bouchaud, Celeste C. and Kebbe, Maryam and Bergeron, Coralie and Civi, Rana Madani and Rhodes, Ryan E. and Farnesi, Biagina Carla and Bouguila, Nizar and Conklin, Annalijn I. and Lear, Scott A. and Cohen, Tamara R.},
