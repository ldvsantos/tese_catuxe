	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85055275287&doi=10.1002%2Fldr.3166&partnerID=40&md5=cffffda60ec1d97d50dce70eba9e78a3},
	affiliations = {Khon Kaen University, Program on System Approaches in Agriculture for Sustainable Development, Khon Kaen, Thailand; Khon Kaen University, Soil Organic Matter Management Research Group, Khon Kaen, Thailand; East-West Center, Honolulu, United States},
	abstract = {Most ethnopedological research has been based on information collected in group interviews. Resulting descriptions of indigenous soil taxonomies represent group consensus views and ignore variations among individuals. In this study, 11 Thai-Lao farmers in a village in Northeast Thailand were individually interviewed about their knowledge of local paddy soils. They identified 14 named soils in their fields. Texture, color, softness, and taste were the main indicators employed to identify soils, with texture the most commonly used criterion. Agreement among informants about the names of the various soil types was surprisingly low, with as many as seven names applied to the same soil type. The farmers also differed in the ways they classified the different soil types into larger groups; six farmers divided them into four groups, and five farmers divided them into three groups. This lack of consensus about soil names and classification among members of the same small community may reflect the way that villagers acquire their knowledge of soils. Soil knowledge is transmitted vertically from parents to their children within families but is rarely or never shared horizontally with fellow villagers. Soil knowledge is a type of familial microculture rather than a widely shared body of knowledge within the whole community. This finding suggests that land use planners and rural development practitioners should be cautious in basing their plans for community management of soil resources on existing studies of indigenous soil knowledge without first establishing how widely shared this knowledge is among community members. © 2018 Elsevier B.V., All rights reserved.},
