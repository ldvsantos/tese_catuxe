}

@ARTICLE{Kolawole2022125,
	author = {Kolawole, Oluwatoyin Dare and Cooper, Garrick Wayne},
	title = {Classifying Soils: Points of Convergence in Indigenous Knowledge Engagement with Scientific Epistemologies},
	year = {2022},
	journal = {International Journal of African Renaissance Studies},
	volume = {17},
	number = {1},
	pages = {125 - 145},
	doi = {10.1080/18186874.2022.2035784},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85125915446&doi=10.1080%2F18186874.2022.2035784&partnerID=40&md5=762c3b4f03c8a1d938f9cb326c0e7918},
	affiliations = {University of Botswana, not available, United States; University of Canterbury, Christchurch, New Zealand},
	abstract = {While cultures are diverse in nature, there are many similarities between them. This is the case with African and Maōri cultures. Local people largely view their realities in a similar way. The question as to whether there are similarities in the indigenous epistemologies related to farming activities in different regions (such as West Africa, southern Africa, and Oceania) therefore arises. Given that no form of knowledge is mutually exclusive, we attempt to seek the points of convergence between local or indigenous knowledge and scientific modes of enquiry in relation to soil fertility management. In addition to secondary information, qualitative data were purposively obtained from key informants in selected farming communities in northwestern Botswana, the Canterbury province in New Zealand (Aotearoa), and southwestern Nigeria. We hypothesise that local farmers’ ways of knowing related to soil fertility and management have commonalities with mainstream science, particularly in terms of soil classification. Our findings show that both scientific and indigenous epistemologies as regards soil fertility are based on certain indicators, including soil morphology, the presence of fauna, plant growth, and so forth. While African farmers used the “principle of mental economy” to determine soil suitability, Māori farmers systematically group various soils, which is an indication of their sophisticated environmental knowledge. © 2022 Elsevier B.V., All rights reserved.},
	author_keywords = {Botswana; epistemology; local knowledge; New Zealand; Nigeria; science; soil management},
	correspondence_address = {O.D. Kolawole; University of Botswana, Eastern University, United States; email: tkolawole@ub.ac.bw},
	publisher = {Taylor and Francis Ltd.},
	issn = {18186874; 17537274},
	language = {English},
	abbrev_source_title = {Int. J. Afr. Renaiss. Stud.},
