@ARTICLE{Solís-Rojas2019,
	author = {Solís-Rojas, Leonor and Casas, Alejandro},
	title = {Cuicatec ethnozoology: traditional knowledge, use, and management of fauna by people of San Lorenzo Pápalo, Oaxaca, Mexico},
