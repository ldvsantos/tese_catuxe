@ARTICLE{Tefera2025,
	author = {Tefera, Yirefu and Lulekal, Ermias and Dullo, Bikila Warkineh},
	title = {Human–forest interaction of useful plants in the Wof Ayzurish Forest, North Showa Zone, Ethiopia: cultural significance index, conservation, and threats},
