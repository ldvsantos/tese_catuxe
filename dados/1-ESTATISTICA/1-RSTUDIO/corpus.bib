@ARTICLE{Zovo2022241,
	author = {Zovo, Cecilia Dal},
	title = {Performance, pilgrimage, and perspective in the mongolian landscape: From the venice biennale to the gobi-Al tai mountains},
	year = {2022},
	journal = {Rivista degli Studi Orientali},
	volume = {95},
	number = {3},
	pages = {241 - 257},
	doi = {10.19272/202203803016},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85173773149&doi=10.19272%2F202203803016&partnerID=40&md5=8c4b5cedae8e02f097cde42a61bc52b2},
	affiliations = {Consejo Superior de Investigaciones Científicas, Institute of Heritage Studies (Incipit), Madrid, Spain},
	abstract = {The construction of the landscape through signifying practices and local narratives has been investigated from multiple perspectives in different regions of the world. This paper focuses on performance and ritual in the Mongolian landscape, which take place within a local cosmological framework that consistently integrates movement. To understand the multi-layered meanings and contextual variability of those practices, two case studies have been considered: An itinerant artistic performance by the Mongolian artist Enkhbold Togmidshiirevat at the Venice Biennale in 2015 and a high-Altitude mountain trip, interpreted as a circular pilgrimage, in the area of the Gobi-Altai Mountains. These mobility practices may appear eminently different, yet they are inextricably united by their performative character, as well as the landscape context. Drawing from the idea of performing landscape and the local conceptualisation of animated landscape, this study posits that the Mongolian landscape can be one of the subjects and not simply the object or the mere setting of performance and ritual movement. This comparative analysis is thus aimed at critically challenging the limits of non-local binary classifications of movement and landscape in academic research. Through a reassessment of archaeological and anthropological investigation, the role of local knowledge, movement, and animated agencies in shaping the highly interconnected but increas ingly endangered Mongolian landscape can be acknowledged. © 2023 Elsevier B.V., All rights reserved.},
	author_keywords = {Central Asia; Land Art Mongolia 360; Landscape; Movement; Performance; Pilgrimage; Sacred Mountains; Venice Biennale},
	correspondence_address = {C.D. Zovo; Institute of Heritage Studies, Spanish National Research Council, Spain; email: cecilia.dalzovo@incipit.csic.es},
	publisher = {Fabrizio Serra Editore Srl},
