@ARTICLE{Poncet2015,
	author = {Poncet, Anna and Vogl, Christian Reinhard and Weckerle, Caroline S.},
	title = {Folkbotanical classification: Morphological, ecological and utilitarian characterization of plants in the Napf region, Switzerland},
	year = {2015},
	journal = {Journal of Ethnobiology and Ethnomedicine},
	volume = {11},
	number = {1},
	pages = {},
	doi = {10.1186/1746-4269-11-13},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84929009218&doi=10.1186%2F1746-4269-11-13&partnerID=40&md5=a8063360ff298e9d9630b8419323859e},
	affiliations = {BOKU University, Department of Sustainable Agricultural Systems, Vienna, Austria; Universität Zürich, Institute of Systematic Botany, Zurich, Switzerland},
	abstract = {Background: Discussions surrounding ethnobiological classification have been broad and diverse. One of the recurring questions is whether classification is mainly based on the "inherent structure of biological reality" or on cultural, especially utilitarian needs. So far, studies about ethnobotanical classification have mainly been done in indigenous societies. Comparable data from industrialized countries are scarce. In this paper, folkbotanical classification data from the Napf region in central Switzerland is analysed and cross-culturally compared. Methods: Structured and semi-structured interviews were conducted with 60 adults and children chosen by random sampling. Descriptive statistics, t-tests and cultural domain analysis were used to analyze the data. Results: Close to 500 folk taxa have been documented during field work. As life-form taxa appeared tree, bush, grass, herb, flower, and mushroom. Intermediate taxa mentioned regularly were sub-categories of the life form tree and bush, i.e. conifer, deciduous tree, fruit tree, stone fruits, pomaceous fruits, and berry bush. The rank of the folk generic was by far the largest with 316 taxa (85.4% monotypical). The specific rank contained 145 taxa, the varietal 14 taxa. The 475 generic, specific and varietal folk taxa could be assigned to 298 wild growing plant species, which make up 28.13% of the local flora, and to 213 cultivated plant species, subspecies and cultivars. Conclusion: The classification system of the Napf region is comparable to classification systems of indigenous societies, both in its shallow hierarchical structure and in the amount of recognized taxa. © 2023 Elsevier B.V., All rights reserved.},
	author_keywords = {Ethnobotanical classification; Ethnobotany; Local plant knowledge; Switzerland},
	keywords = {Basidiomycota; Coniferophyta; adolescent; adult; age; aged; child; classification; cultural anthropology; ecology; edible plant; ethnobotany; female; flower; folklore; fruit; human; interview; male; middle aged; plant; plant leaf; Switzerland; young adult; Adolescent; Adult; Age Factors; Aged; Child; Culture; Ecology; Ethnobotany; Female; Flowers; Folklore; Fruit; Humans; Interviews as Topic; Male; Middle Aged; Plant Leaves; Plants; Plants, Edible; Young Adult},
	correspondence_address = {S. Weckerle; University of Zürich, Institute of Systematic Botany, Zürich, Zollikerstrasse 107, CH-8008, Switzerland; email: caroline.weckerle@systbot.uzh.ch},
