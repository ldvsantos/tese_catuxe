@ARTICLE{Rakotoarivelo2015,
	author = {Rakotoarivelo, Nivo H. and Rakotoarivony, Fortunat and Ramarosandratana, Aro Vonjy and Jeannoda, Vololoniaina Harimanga and Kuhlman, Alyse R. and Randrianasolo, Armand and Bussmann, Rainer W.},
