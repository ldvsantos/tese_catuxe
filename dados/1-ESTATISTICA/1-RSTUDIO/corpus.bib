@ARTICLE{Rantshabeng2024,
	author = {Rantshabeng, Patricia S. and Tsima, Billy M. and Ndlovu, Andrew Khulekani and Motlhatlhedi, Keneilwe and Sharma, Kirthana and Masole, Carol B. and Moraka, Natasha Onalenna and Motsumi, Kesego and Maoto-Mokote, Angela K.T. and Eshetu, Alemayehu Bekele and Tawe, Leabaneng and Gaolathe, Tendani and Moyo, Sikhulile M. and Kyokunda, Lynnette Tumwine},
	title = {High-risk human papillomavirus diversity among indigenous women of western Botswana with normal cervical cytology and dysplasia},
	year = {2024},
	journal = {BMC Infectious Diseases},
