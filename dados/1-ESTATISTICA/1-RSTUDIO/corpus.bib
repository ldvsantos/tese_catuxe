	author = {Singh, Bikarma N. and Sultan, Phalisteen and Hassan, Qazi Parvaiz and Gairola, Sumeet and Bedi, Yashbir Singh},
	title = {Ethnobotany, Traditional Knowledge, and Diversity of Wild Edible Plants and Fungi: A Case Study in the Bandipora District of Kashmir Himalaya, India},
	year = {2016},
	journal = {Journal of Herbs, Spices and Medicinal Plants},
