	keywords = {Behavioral research; Biodiversity; Conservation; Decision making; Ecosystems; Environmental protection; Knowledge management; Land use; Sustainable development; Adi tribe; Ecosystem services; Forest classification; Livelihoods; Traditional ecological knowledge; Forestry; classification; community forestry; ecosystem service; forest management; livelihood; nature conservation; traditional knowledge; Arunachal Pradesh; Himalayas; India; Animalia},
