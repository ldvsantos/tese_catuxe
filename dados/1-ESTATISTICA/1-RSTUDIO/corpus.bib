@ARTICLE{Nergård2015,
	author = {Nergård, Cecilie Sogn and Ho, Thi Phung Than and Diallo, Drissa and Ballo, Ngolo and Paulsen, Berit Smestad and Nordeng, Hedvig Marie Egeland},
	title = {Attitudes and use of medicinal plants during pregnancy among women at health care centers in three regions of Mali, West-Africa},
	year = {2015},
	journal = {Journal of Ethnobiology and Ethnomedicine},
