	note = {Cited by: 4}
}

@ARTICLE{Gras2020,
	author = {Gras, Airy and Vallès, Joan and Garnatje, Teresa},
	title = {Filling the gaps: Ethnobotanical study of the Garrigues district, an arid zone in Catalonia (NE Iberian Peninsula)},
