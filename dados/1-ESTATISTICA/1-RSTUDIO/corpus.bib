@ARTICLE{Frazão-Moreira2021,
	author = {Frazão-Moreira, Amélia and Carvalho, Ana Maria},
	title = {Gendered plants and plant categorization by gender: Classificatory and “storied” knowledge in trás-os-montes, portugal},
	year = {2021},
