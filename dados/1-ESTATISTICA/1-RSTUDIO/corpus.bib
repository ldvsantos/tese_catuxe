@ARTICLE{Santos2018297,
	author = {Santos, Carina Silva and Barros, Fernanda Novais and de Paula, Marcelo and Rando, Juliana Gastaldello and Do-Nascimento, Viviany Teixeira and Medeiros, Patrícia Muniz De},
	title = {What matters when prioritizing a medicinal plant? A study of local criteria for their differential use},
