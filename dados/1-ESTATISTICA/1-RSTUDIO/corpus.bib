@ARTICLE{Motiejǔnaite2024,
	author = {Motiejǔnaite, Jurga and Džekčioriūtė-Medeišienė, Vita and Kutorga, Ernestas and Kasparavičius, Jonas and Iršėnaitė, Reda},
	title = {Diversity of ethnomycological knowledge and mushroom foraging culture in a small nation: case of Lithuania},
	year = {2024},
	journal = {Journal of Ethnobiology and Ethnomedicine},
	volume = {20},
