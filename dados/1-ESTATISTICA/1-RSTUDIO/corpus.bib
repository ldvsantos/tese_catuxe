	title = {Naming, Classification, and management of paddy soils by Thai-Lao rice farmers in a village in Northeast Thailand},
	year = {2020},
	journal = {Geoderma},
	volume = {369},
	pages = {},
	doi = {10.1016/j.geoderma.2020.114332},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85082111467&doi=10.1016%2Fj.geoderma.2020.114332&partnerID=40&md5=c9486468702d963bf4145c14bd25e450},
	affiliations = {Khon Kaen University, Program on System Approaches in Agriculture for Sustainable Development, Khon Kaen, Thailand; Khon Kaen University, Soil Organic Matter Management Research Group, Khon Kaen, Thailand; East-West Center, Honolulu, United States},
	abstract = {The indigenous soil knowledge of Thai-Lao paddy farmers in a village in Northeast Thailand is described in this paper. Eleven farmers were individually interviewed about the names of soils in their paddy fields. Soil samples collected from their fields were shown to each of the informants who assigned 11 different names to them. No farmer used all of these names and no sample was given the same name by all informants. Consensus ranged from 36.4% to 81.8%. Concordance between soil names used by the farmers and the scientific categorization of sample texture classes was limited. The farmers differed in their classification of the samples into larger taxonomic groups. Nine farmers classified the samples into three groups but two divided them into two groups. The lack of agreement among informants about soil names and classification may result from the way that they learned soil knowledge. Children learn about soil from their parents, but adults rarely discuss soils with neighbors. Moreover, in discussing how they managed soils in their paddy fields, the farmers did not refer to specific named soil types but instead only mentioned gross differences in texture as influencing management practices. The extent to which other ethnic groups may have similar individual heterogeneity in soil knowledge remains an unanswered question that has largely been ignored in the ethnopedological literature. Therefore, it is suggested that data collection methods designed to reveal the existence of inter-informant variability in soil knowledge should be employed in future research with other ethnic groups. © 2020 Elsevier B.V., All rights reserved.},
	author_keywords = {Ethnopedological research methods; Ethnopedology; Familial micro-culture; Farmer knowledge; Paddy soils; Rain-fed rice agriculture},
	keywords = {Agriculture; Rural areas; Textures; Data collection method; Ethnopedological research methods; Ethnopedology; Farmer knowledge; Management practices; Northeast Thailand; Paddy soils; Similar individuals; Soils; classification; heterogeneity; indigenous knowledge; management practice; pedology; rainfed agriculture; research method; rice; sampling; soil management; Thailand},
	correspondence_address = {A.T. Rambo; Program on Systems Approaches in Agriculture for Sustainable Development, Department of Agricultural Extension and Agricultural Systems, Faculty of Agriculture, Khon Kaen University, Khon Kaen, 40002, Thailand; email: rambo@kku.ac.th},
	publisher = {Elsevier B.V.},
	issn = {00167061},
	coden = {GEDMA},
	language = {English},
	abbrev_source_title = {Geoderma},
	type = {Article},
