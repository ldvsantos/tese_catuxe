	language = {English},
	abbrev_source_title = {Glob. Ecol. Conserv.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 13; All Open Access; Gold Open Access; Green Final Open Access; Green Open Access}
}

