@article{Orimi2015,
   abstract = {Prediction of river flows requires the use of computer facilities and the latest innovations in this field. Artificial Neural Networks (ANNs), as a data-driven approach, are widely and successfully used in the management of water resources, which includes river flow forecasts. However, not using a number of parameters that influence the flow of streams as an input to the network will significantly reduce the performance of the model. One of these parameters, especially in snow basins, is snow. Snow Water Equivalent (SWE) is a common parameter in river flow modeling and is used to effect the snow in the models. This study attempts to introduce cumulative precipitation parameters (Cprecip) instead of SWE. Some basins lack the required SWE; therefore, the Cprecips are applied in order to cope with the changes in these basins. The results show that the Cprecip can be used to replace the SWE when the suitable changes occur according to the conditions of the studied basin. © 2015, Pleiades Publishing, Ltd.},
   author = {M G Orimi and A Farid and R Amiri and K Imani},
   doi = {10.1134/S0097807815050073},
   issn = {00978078 (ISSN)},
   issue = {5},
   journal = {Water Resources},
   keywords = {Artificial Neural Network,Haraz River,Iran,Mazandaran,artificial neural network,cumulative precipitation parameters (Cprecip),flow modeling,hydrological modeling,performance assessment,prediction,river basin,river discharge,river flow,snow,snow water equivalent,water management,weekly discharge prediction},
   note = {Cited By :1<br/><br/><br/><br/>CODEN: WARED<br/><br/><br/><br/>Correspondence Address: Orimi, M.G.; Department of Civil Engineering, Ferdowsi University of MashhadIran<br/><br/><br/><br/>Export Date: 19 March 2020<br/><br/><br/><br/>References: Yasinskii, S.V., Kashutina, E.A., Effect of regional climate variations and economic activity on changes in the hydrological regime of watersheds and small-river runoff (2012) Wat. Res., 39 (3), pp. 272-293; <br/>Adeloye, A.J., Rustum, R., Self-organising map rainfall-runoff multivariate modelling for runoff reconstruction in inadequately gauged basins (2012) Hydrol. Res., 43 (5), pp. 603-617;<br/>Akhtar, M.K., Corzo, G.A., Van Andel, S.J., Jonoski, A., River flow forecasting with Artificial Neural Networks using satellite observed precipitation preprocessed with flow length and travel time information: case study of the Ganges river basin (2009) Hydrol. Earth Syst. Sci. Discuss., 6, pp. 3385-3416;<br/>Alvisi, S., Bernini, A., Franchini, M., A conceptual grey rainfall-runoff model for simulation with uncertainty (2013) J. Hydroinform., 15 (1), pp. 1-20;<br/>Alvisi, S., Creaco, E., Franchini, M., Crisp discharge forecasts and grey uncertainty bands using datadriven models (2012) Hydrol. Res., 43 (5), pp. 589-602;<br/>Amiri, R., Bazargan-Lari, M.R., Gouranorimi, M., Alaei, S., Safari, S., (2012) River Flow forecasting using ANN and SVM: A Case Study;<br/>Hydrologic applications, J. Hydrol. Eng ASCE, 2000\}. vol. 5, 2, pp. 124-137;<br/>Chavoshi, S., Sulaiman, W.A., Saghafian, B., Sulaiman, M.B., Manaf, L.A., Flood prediction in southern strip of Caspian Sea watershed (2013) Wat. Res., 40 (6), pp. 593-605;<br/>De Vos, N.J., Rientjes, T.H.M., Multi-objective performance comparison of an artificial neural network and a conceptual rainfall-runoff model (2007) Hydrol. Sci. J., 52 (3), pp. 397-413;<br/>Dorum, A., Yarar, A., Sevimli, M.F., Onucyildiz, M., Modelling the rainfall–runoff data of susurluk basin (2010) Expert Sys