% Score: 20.0 - Yu2015
@article{Yu2015,
   abstract = {With less than 6% of total global water resources but one fifth of the global population, China is facing serious challenges for its water resources management, particularly in rural areas due to the long-standing urban-rural dualistic structure and the economic-centralized developmental policies. This paper addresses the key water crises in rural China including potable water supply, wastewater treatment and disposal, water for agricultural purposes, and environmental concerns, and then analyzes the administrative system on water resources from the perspective of characteristics of the current administrative system and regulations; finally, synthetic approaches to solve water problems in rural China are proposed with regard to institutional reform, regulation revision, economic instruments, technology innovation and capacity-building. These recommendations provide valuable insights to water managers in rural China so that they can identify the most appropriate pathways for optimizing their water resources, reducing the total wastewater discharge and improving their water-related ecosystem. © 2015 by the authors; licensee MDPI, Basel, Switzerland.},
   author = {X Yu and Y Geng and P Heck and B Xue},
   doi = {10.3390/su7055773},
   issn = {20711050 (ISSN)},
   issue = {5},
   journal = {Sustainability (Switzerland)},
   keywords = {China,Integrated water management,Rural China,Water availability,Water pollution,administrative framework,drinking water,environmental legislation,integrated approach,rural area,water availability,water management,water pollution,water supply},
   note = {},
   pages = {5773-5792},
   title = {A review of china's rural water management},
   volume = {7},
